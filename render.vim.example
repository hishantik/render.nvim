" render.nvim - Configuration Example
" Copy this to your nvim init file or source this file

" Server Configuration
" --------------------
" Server log file location
" let g:render_server_log = "/tmp/render_server_logfile"

" Server URL (default: http://127.0.0.1)
" let g:render_server_path = "http://127.0.0.1"

" Server port (default: pid-based for multiple instances)
" let g:render_server_port = 13378

" Allow remote connections (for mobile preview on same network)
" let g:render_server_allow_remote_connections = 0


" Browser Configuration
" --------------------
" Browser command (0 = auto-detect, or specify like 'google-chrome')
" let g:render_browser_command = 0

" Auto-open browser when :Render is called
" let g:render_auto_start_browser = 1


" Behavior Configuration
" --------------------
" Auto-start Node server
" let g:render_auto_start_server = 1

" Evaluate JavaScript when saving .js/.ts/.tsx files
" let g:render_eval_on_save = 1

" Reload page when saving .html files
" let g:render_refresh_on_save = 0


" Validation Configuration
" --------------------
" HTML validation rules (HTMLHint)
" let g:render_html_rules = {}

" CSS validation rules (CSSLint)
" let g:render_csslint_rules = []


" Example: Mobile Preview Setup
" ----------------------------
" To test on mobile devices connected to the same network:
"
" 1. Enable remote connections:
"    let g:render_server_allow_remote_connections = 1
"
" 2. Start render:
"    :Render
"
" 3. Open QR code:
"    :RenderMobile
"
" 4. Scan the QR code with your mobile device


" Example: Custom Validation Rules
" --------------------------------
" HTML rules (tag-pair, attr-lowercase, etc.)
" let g:render_html_rules = {
"     \ 'tag-pair': v:true,
"     \ 'attr-lowercase': v:true,
"     \ 'doctype-first': v:false
" \ }
"
" CSS rules (compatible-vendor-prefixes, box-model, etc.)
" let g:render_csslint_rules = ['compatible-vendor-prefixes']